generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ============ AUTH ============

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  hashedPassword String?
  image          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Settings
  defaultStance    String    @default("balanced")
  onboardingDone   Boolean   @default(false)

  // Legal
  acceptedTermsAt  DateTime?                        // null = not yet accepted
  acceptedTermsVersion String?                      // "2026-03-24-v1"

  // Role & Subscription
  role             String    @default("user")       // "user" | "admin"
  subscriptionTier String    @default("free")       // "free" | "starter" | "pro" | "enterprise"
  credits          Int       @default(50)           // current credit balance
  creditsResetAt   DateTime?                        // monthly credit reset timestamp

  // Stripe
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?

  // Relations
  accounts        Account[]
  sessions        Session[]
  strategies      StrategySession[]
  calendarEvents  CalendarEvent[]
  aiMemories      AiMemory[]
  activityLogs    ActivityLog[]
  actionPlans     ActionPlan[]
  financeEntries  FinanceEntry[]
  channelTrackers ChannelTracker[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============ STRATEGY SESSIONS ============

model StrategySession {
  id        String   @id @default(cuid())
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Business profile data (JSON)
  profileJson String @default("{}")

  // Diagnosis results (JSON)
  valueDiagnosisJson String?
  healthScoreJson    String?
  platformJson       String?
  strategyJson       String?

  // State
  activeModule  String  @default("intake")
  intakeComplete Boolean @default(false)

  // Metadata
  name        String  @default("Untitled Business")
  description String?
  archived    Boolean @default(false)

  // Relations
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages      Message[]
  conversations Conversation[]

  @@index([userId])
}

model Message {
  id             String   @id @default(cuid())
  sessionId      String
  conversationId String?  // Thread grouping (null = legacy/default)
  role           String   // user, assistant, system
  content        String
  module         String   @default("general")
  createdAt      DateTime @default(now())
  metadata       String?  // JSON for extra data

  session      StrategySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  conversation Conversation?   @relation(fields: [conversationId], references: [id])

  @@index([sessionId])
  @@index([conversationId])
}

// ============ CONVERSATIONS ============

model Conversation {
  id        String   @id @default(cuid())
  sessionId String
  title     String   @default("New Conversation")
  module    String?  // Primary module context
  pinned    Boolean  @default(false)
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session  StrategySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([sessionId, updatedAt])
}

// ============ AI MEMORY ============

model AiMemory {
  id        String   @id @default(cuid())
  userId    String
  key       String   // e.g., "business_style", "preferred_channels"
  value     String   // stored insight
  category  String   // business, preference, learning, context
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  expiresAt DateTime? // optional TTL for time-sensitive memories

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId, category])
}

// ============ CALENDAR ============

model CalendarEvent {
  id        String   @id @default(cuid())
  userId    String
  title     String
  description String?
  date      DateTime
  endDate   DateTime?
  type      String   // campaign, post, launch, review, research, custom
  status    String   @default("scheduled") // scheduled, in_progress, completed, skipped
  priority  String   @default("medium") // low, medium, high, critical
  module    String?  // which MadAi module generated this
  sessionId String?  // linked strategy session
  metadata  String?  // JSON for extra data
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([userId, status])
}

// ============ ACTION PLANS ============

model ActionPlan {
  id          String   @id @default(cuid())
  userId      String
  sessionId   String?  // linked strategy session
  title       String
  description String?
  status      String   @default("draft") // draft, active, completed, archived
  planJson    String   @default("[]") // JSON array of steps
  metricsJson String?  // JSON for KPIs and tracking data
  horizon     String   @default("90-day") // 30-day, 90-day, 6-month, 1-year
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  items ActionPlanItem[]

  @@index([userId, status])
}

model ActionPlanItem {
  id          String   @id @default(cuid())
  planId      String
  title       String
  description String?
  status      String   @default("pending") // pending, in_progress, completed, skipped
  priority    String   @default("medium") // low, medium, high, critical
  dueDate     DateTime?
  frequency   String?  // daily, weekly, monthly, one-time
  category    String?  // marketing, sales, product, operations, research
  metrics     String?  // JSON for item-specific metrics
  notes       String?
  sortOrder   Int      @default(0)
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  plan ActionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId, status])
}

// ============ ACTIVITY LOG ============

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  action    String   // session_created, analysis_run, strategy_generated, research_conducted, etc.
  details   String?  // JSON
  module    String?
  sessionId String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// ============ FINANCE TRACKING ============

model FinanceEntry {
  id          String   @id @default(cuid())
  userId      String
  sessionId   String?
  type        String   // "revenue" | "expense" | "investment"
  category    String   // "ad_spend" | "tools" | "contractor" | "sales" | "subscription" | "other"
  amount      Float
  description String?
  date        DateTime
  recurring   Boolean  @default(false)
  metadata    String?  // JSON
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([userId, type])
}

// ============ CHANNEL TRACKING ============

model ChannelTracker {
  id           String   @id @default(cuid())
  userId       String
  sessionId    String?
  platform     String   // "instagram" | "tiktok" | "youtube" | "email" | "website" | "reddit" | etc.
  followers    Int?
  engagement   Float?   // percentage
  posts        Int?     // posts this period
  revenue      Float?   // revenue attributed to this channel
  notes        String?
  snapshotDate DateTime @default(now())
  metadata     String?  // JSON

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, platform])
  @@index([userId, snapshotDate])
}
